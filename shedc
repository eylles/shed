#!/bin/sh

mypid="${$}"

# source shed library
. ./libshed.sh

# shedc
# ---------------------------------
# the SHell Execution Daemon Client
prog="${0##*/}"

PrettyPrint=""

# Return type: string
#       Usage: progspinner prefix [time]
#         prefix: the string the will appear before the progress spinner
#           time: optional, amount of time the spinner will be spinning for,
#                 by default 2 seconds
#      Return: spinner
progspinner() {
  count=0
  spinSymbol=0
  progspinner=0
  progspinnerPrefix="$1"
  if [ -z "$2" ]; then
    totaltime=2
  else
    totaltime="$2"
  fi
  steptime=$(awk -v tt="$totaltime" 'BEGIN {printf "%.2f", tt/20}')

  while [ "$count" -le 20 ]; do
    case "$spinSymbol" in
      0) spin="-" ;;
      1) spin="\\" ;;
      2) spin="|" ;;
      3) spin="/" ;;
    esac
    printf ' %s%3d%s\r' "$progspinnerPrefix $spin   [" "$progspinner" "%]"
    sleep "$steptime"
    count=$(( count + 1 ))
    spinSymbol=$(( spinSymbol + 1 ))
    progspinner=$(( progspinner + 5 ))
    [ "$spinSymbol" -gt 3 ] && spinSymbol=0
  done
  printf '  %s%3d%s\r' "$progspinnerPrefix    [" "100" "%]"
  sleep 0.1
  printf '\n'
}

# Return type: string
#       Usage: pretty_print file
# --------------------------------------------------
# uses awk to print the contents of the passed file to the terminal.
pretty_print() {
    awk '
      {
        if (NR==1) {
          printf " ┌"; for(c=0;c<65;c++) printf"─"; printf "┐\n" ;
          printf " │ %63s │\n", $0 ;
          printf " ├"; for(c=0;c<22;c++) printf"─"; printf "┬";
          for(c=0;c<32;c++) printf"─"; printf "┬";
          for(c=0;c<9;c++) printf"─"; printf "┤\n" ;
          printf " │ %20s │ %30s │ %7s │\n", "date", "service", "status";
          printf " ├"; for(c=0;c<22;c++) printf"─"; printf "┼";
          for(c=0;c<32;c++) printf"─"; printf "┼";
          for(c=0;c<9;c++) printf"─"; printf "┤\n" ;
          }
        else { printf " │ %20s │ %30s │ %7s │\n", $1, $2, $3 };
      }
      END { printf " └"; for(c=0;c<22;c++) printf"─"; printf "┴";
          for(c=0;c<32;c++) printf"─"; printf "┴";
          for(c=0;c<9;c++) printf"─"; printf "┘\n" ;}
      ' "$1"

}

# Return type: string
#       Usage: read_reply
#      Return: string from called function
# --------------------------------------------------
#  it will read the contents of the reply file and print them to the terminal
#  with either the pretty_print or read_file with "  " as prefix, this is
#  determined by $PrettyPrint being set or not.
read_reply() {
  progspinner "retrieving status:"
  if [ -z "$PrettyPrint" ]; then
    read_file "$msg_reply" "  "
  else
    pretty_print "$msg_reply"
  fi
}

# Return type: string
#       Usage: read_pipe pipe_file
# --------------------------------------------------
# reads the contents of the passed named pipe, will time out in 10 seconds if
# nothing is written to the pipe.
# this is somewhat unreliable in this implementation and needs more work.
read_pipe() {
  # all messages read will be stored here
  varfile="/tmp/${prog}_${mypid}"
  # pipe we read from
  pipe="${1}"
  # we wait max 10 seconds without reply
  waittime=10
  # we cycle twice per second
  cycles=$((waittime * 2))

  cont=0
  while [ "$cont" = 0 ]; do
    : > "$varfile"
    var=""
    cat "$pipe" > "$varfile" &
    catpid=$!
    var=$(cat "$varfile")
    if [ -z "$var" ]; then
      count=0
      while [ "$count" -le "$cycles" ] && [ -z "$var" ]; do
        sleep 0.5
        var=$(cat "$varfile")
        count=$((count + 1))
      done
      kill $catpid 2>/dev/null
    fi
    if [ -z "$var" ]; then
      # echo "timeout: no message received"
      cont=1
    else
      printf '%s\n' "$var"
    fi
  done

  rm "$varfile"
}

# Return type: string
#       Usage: get_procstatus spiddir sfile
#       spiddir: full path to directory where pid files are stored
#       sfile: full path to the service definition file
get_procstatus() {
  s_pid_dir="$1"
  shift
  ServiceFile="$1"
  shift
  s_name="${ServiceFile##*/}"
  s_exec=""
  s_pid=""
  s_state=""
  s_exec="$(readkeyvalprop "EXEC" "$ServiceFile")"
  # needed for services that got $HOME/path/service in their EXEC def
  s_exec=$(printf '%s\n' "$s_exec" | sed "s@\$HOME@$HOME@")
  # get the full path of the binary
  s_exec=$(command -v "$s_exec")
  if [ -f "${s_pid_dir}/${s_name}.pid" ]; then
    s_pid=$(read_file "${s_pid_dir}/${s_name}.pid")
    if kill -0 "$s_pid" 2>/dev/null && ! is_oneshot "$ServiceFile"; then
      s_state="+"
    else
      s_state="?"
    fi
    if [ -f "${s_pid_dir}/${s_name}.est" ]; then
      s_state=$(head "${s_pid_dir}/${s_name}.est")
    fi
  else
      s_state="-"
  fi
  if [ "$PrettyPrint" = 1 ]; then
    printf ' [ %s ] %30s %*s %s\n' "$s_state" "$s_name" "$pw" "$s_pid" "$s_exec"
  else
    printf ' [ %s ] %s\n' "$s_state" "$s_name"
  fi
}

# Return type: string
#       Usage: print_procstatus_header "NAME"
#        NAME: identifier for the type of proc, so far shed only manages
#              services and components.
print_procstatus_header () {
  if [ "$PrettyPrint" = 1 ]; then
    printf '%6s %30s %*s %s\n' \
      "STATUS" "$1" "$pw" "PID" "EXECUTABLE"
  fi
}

# Return type: string
#       Usage: procstat all | <service name>
#            all: status for all services
# <service name>: status of service
#      Return: status string
# --------------------------------------------------
# for a specific process the status string is:
#   [ stat ] <service name>
#
# for all processes the information is printed as:
#   [ stat ] <service name>
#
# when PrettyPrint is set the print out is as follows:
#   [ stat ] <service name> pid executable
#
#   stat   |  meaning
#    -     |  not running
#    +     |  running
#    ?     |  was started
#    0     |  single shot terminated succesfully
#    1     |  single shot terminated unsuccesfully
procstat() {
  if [ -z "$1" ] || [ "all" = "$1" ]; then
    if [ "$PrettyPrint" = 1 ]; then
      # default pid length
      pidmax=30000
      # use per system pid length
      os_type=$(uname -s)
      case "${os_type}" in
        Linux)
          pidmax=$(head /proc/sys/kernel/pid_max)
          ;;
        NetBSD)
          pidmax=30000
          ;;
        OpenBSD|FreeBSD|*BSD)
          pidmax=99999
          ;;
      esac
      pw=$(printf '%s\n' "$pidmax" | wc -c)
    fi
    if ! is_dir_empty "$ServicesDir"; then
      print_procstatus_header "SERVICE"
      for i in "${ServicesDir}"/* ; do
        get_procstatus "${shed_service_pid_dir}" "$i"
      done
    else
      msg_send "Dir '$ServicesDir' is empty!"
    fi
    if ! is_dir_empty "$ComponentsDir"; then
      print_procstatus_header "COMPONENT"
      for i in "${ComponentsDir}"/* ; do
        get_procstatus "${shed_component_pid_dir}" "$i"
      done
    else
      msg_send "Dir '$ComponentsDir' is empty!"
    fi
  else
    print_procstatus_header "SERVICE"
    for i in "${ServicesDir}"/* ; do
      ServiceFileName="${i##*/}"
      if [ "$ServiceFileName" = "$1" ]; then
        get_procstatus "${shed_service_pid_dir}" "$i"
      fi
    done
  fi
}

# Return type: void
#       Usage: daemon_send <action> all | <service name>
#       <action>: hup, stop, start, reload
#            all: apply action to all services
# <service name>: service to perform action on
# --------------------------------------------------
# sends requests to the shed daemon
daemon_send() {
  printf '%s %s\n' "$1" "$2" > "${ShedSessionDir}/socket"
}

# Return type: void
#       Usage: kill_session
# --------------------------------------------------
kill_session() {
  killprocs "all"
  killcomps "all"
  daemon_send "wait-logout"
  sleep 1
  [ -z "$dry_run" ] && rm -rf "$ShedSessionDir"
  [ -z "$dry_run" ] && kill "$SHED_SESSION_PID"
}

show_version() {
  printf '%s\n' "$prog_v"
}

show_info() {
  if [ "$UsingOldShedDir" -eq "$_true" ]; then
    printf '%s\n' "$prog: shed is using the Old shed dir '$ShedSessionDir'"
  fi
  if [ ! -d "$shed_service_pid_dir" ]; then
    printf '%s\n' "$prog: shed not using $shed_service_pid_dir, relaunch now!"
  fi
  if [ -r "$shed_info" ]; then
    printf '%s=%s\n' "PID" "$(head "$startfile")"
    printf '%s=%s\n' "CLIENTV" "$prog_v"
    head "$shed_info"
    exit $_true
  else
    printf '%s\n' "running shed daemon does not support this option"
    printf '%s\n' "run shedc reload to re-exec the shed daemon"
    exit $_false
  fi
}

# Return type: string
#       Usage: show_help
# --------------------------------------------------
# prints to terminal
show_help() {
  printf 'Usage: %s [options] { hup | start | stop | restart | status } [service name] | reload | logout \n' "$prog"
  printf '  -n        dry run.\n  -h        show this help.\n'
  printf '  -V        show version.\n'
  printf '  -p        pretty print reply.\n'
  printf '   hup      send hup to the session service(s)\n'
  printf '   stop     send term to the session service(s)\n'
  printf '   start    send request to start the session service(s)\n'
  printf '   restart  send term to the session service(s) and then send request to start the service(s)\n'
  printf '   logout   send term to the session services and the xsession process\n'
  printf '   reload   re-exec shed to run a newe version\n'
  printf '   relaunch send term to the session services and reload shed\n'
  printf '   info     shows version, pid and started date of shed daemon\n'
  printf '   status   shows the status of the desired service'
  printf 'for all services the status is shown with a symbol as follows:\n'
  printf '\t     [ + ] means the service is running\n'
  printf '\t     [ - ] means the service is not running\n'
  printf '\t     [ ? ] means the service was started but the pid was not among the active processes\n'
  printf '\t     [ 0 ] means the oneshot service ran succesfully and termianted with exit status 0\n'
  printf '\t     [ 1 ] means the oneshot service ran unsuccesfully and termianted with exit status 1\n'
}

OPTIND=1
while getopts nhpV o; do case "${o}" in
  h) help=1 ;;
  n) dry_run=1 ;;
  p) PrettyPrint=1 ;;
  V) version=1 ;;
  *) help=1 ;;
esac done
shift $(( OPTIND - 1 ))

[ -z "$invalid" ] || { show_help ; exit 1 ;}
[ -z "$help" ] || { show_help ; exit; }
[ -z "$version" ] || { show_version ; exit; }
case $1 in
  stop)
    killprocs "$2"
  ;;
  restart)
    killprocs "$2"
    progspinner "restarting service(s)" 1
    daemon_send "start" "$2"
    read_reply
  ;;
  hup)
    hupprocs "$2"
  ;;
  status)
    procstat "$2"
  ;;
  start)
    daemon_send "start" "$2"
    read_reply
  ;;
  logout)
    kill_session
  ;;
  reload)
    if [ ! -d "$shed_service_pid_dir" ]; then
      msg_send "no $shed_service_pid_dir found, running migration routine"
      old_kill_all_procs
    fi
    daemon_send "reload"
    read_reply
  ;;
  relaunch)
    if [ ! -d "$shed_service_pid_dir" ]; then
      msg_send "no $shed_service_pid_dir found, running migration routine"
      old_kill_all_procs
    else
      killprocs "all"
    fi
    progspinner "reloading shed" 2
    daemon_send "reload"
    read_reply
  ;;
  info)
    show_info
  ;;
  *) show_help ; exit 1 ;;
esac
