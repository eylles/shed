export AWT_TOOLKIT="MToolkit wmname LG3D"	#May have to install wmname
export _JAVA_AWT_WM_NONREPARENTING=1	# Fix for Java applications in dwm and awesome
_JAVA_AA_TEXT="-Dawt.useSystemAAFontSettings=on -Dswing.aatext=true"
_JAVA_GNOME_STYLE="-Dswing.defaultlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel -Dswing.crossplatformlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel"
export _JAVA_OPTIONS="${_JAVA_AA_TEXT} ${_JAVA_GNOME_STYLE} ${_JAVA_OPTIONS}"
